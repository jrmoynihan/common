	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package",
		"package-build": "npm run package",
		"login-to-publish": "npm login --scope=@jrmoynihan --registry=https://registry.npmjs.org/",
		"package-publish-patch": "vite build && bun run package && npm version patch && bun publish --access public && git push --follow-tags",
		"package-publish-minor": "vite build && bun run package && npm version minor && bun publish --access public && git push --follow-tags",
		"package-publish-major": "vite build && bun run package && npm version major && bun publish --access public && git push --follow-tags",
		"publish": "bun publish --access public",
		"test": "playwright test && bun run test:unit -- --run",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check --plugin-search-dir=. . && eslint .",
		"format": "prettier --write --plugin-search-dir=. .",
		"test:unit": "vitest"
	},
